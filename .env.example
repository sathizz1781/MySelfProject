# ============================================================
#  ENV TEMPLATE — copy this to .env.local for local dev
#                 copy this to .env.production for live
# ============================================================

# MongoDB Connection URL
# Local example:      mongodb://localhost:27017/nextjs-auth
# Atlas example:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/dbname
MONGODB_URI=

# JWT Secret (use a long random string)
JWT_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=

# Node environment: development | production
NODE_ENV=
